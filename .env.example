MONGODB_URL=mongodb://mongodb:27017
MONGODB_DATABASE=arenamind
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace-with-at-least-32-random-characters
BOOTSTRAP_ADMIN_EMAIL=administrator@arenamind.local
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-bootstrap-password
# Choose groq or gemini. Never commit the corresponding key.
AI_PROVIDER=groq
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
# Optional override for an OpenAI-compatible gateway.
AI_BASE_URL=
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
